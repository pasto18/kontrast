---
// src/layouts/layout.astro
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;

// 1. Detectamos el idioma actual con un fallback seguro
const lang = Astro.currentLocale || 'ca';

// 2. Definimos los textos aquí arriba para que el HTML sea más limpio
const labels = {
  programacion: lang === 'en' ? 'PROGRAM' : 'PROGRAMACIÓ',
  historia: lang === 'en' ? 'LAST EDITIONS' : 'EDICIONS ANTERIORS',
  tickets: 'TICKETS',
  info: 'INFO',
  coches: 'COTXE-SHARING',
  mapa: 'MAPA',
  programa: lang === 'en' ? 'ARTISTS' :'ARTISTES',
  switchLang: lang === 'en' ? 'CATALÀ' : 'ENGLISH',
  switchUrl: lang === 'en' ? '/' : '/en/'
};

// 3. Función para las rutas externas
const usePath = (path: string) => {
  return lang === 'en' ? `/en${path}` : path;
};

// Detectamos si estamos en la home
const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '/en/';
const homePrefix = isHome ? '' : (lang === 'en' ? '/en/' : '/');
---

<!DOCTYPE html>
<html lang={lang}>
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} - Festival</title>
</head>
<body id="body-principal">
    
    <header class="desktop-header" id="desktop-header">
       <!--<a href={isHome ? '#top' : homePrefix} class="desktop-header-logo">KONTRAST</a> --> 
        <a href={isHome ? '#top' : homePrefix}>
            <img src="/img/kontrast6.webp" alt="kontrast" style="height: 30px;">
        </a>

        <nav class="desktop-header-nav">
            <a href={`${homePrefix}#programacion`}>{labels.programacion}</a>
            <a href={usePath("/programa")}>{labels.programa}</a>
            <a href={`${homePrefix}#tickets`}>{labels.tickets}</a>
            <a href={`${homePrefix}#info`}>{labels.info}</a>
            <a href={usePath("/cotxe-sharing-page")}>{labels.coches}</a>
            <a href={usePath("/mapa")}>{labels.mapa}</a>
            <a href={usePath("/edicionsanteriors")}>{labels.historia}</a>
        </nav>
        <a href={labels.switchUrl} class="desktop-header-lang">{labels.switchLang}</a>
    </header>

    <!-- Botó hamburguesa mòbil -->
    <button class="hamburger-btn" id="hamburger-btn" aria-label="Obrir menú">
        <span></span>
        <span></span>
        <span></span>
    </button>

    <!-- Menú fullscreen mòbil -->
    <div class="mobile-menu-overlay" id="mobile-menu-overlay">
        <nav class="mobile-menu-nav">
            <ul>
                <li><a href={`${homePrefix}#programacion`} class="mobile-menu-link">{labels.programacion}</a></li>
                
                <li><a href={`${homePrefix}#tickets`} class="mobile-menu-link">{labels.tickets}</a></li>
                <li><a href={`${homePrefix}#info`} class="mobile-menu-link">{labels.info}</a></li>
                <li><a href={usePath("/cotxe-sharing-page")} class="mobile-menu-link">{labels.coches}</a></li>
                <li><a href={usePath("/mapa")} class="mobile-menu-link">{labels.mapa}</a></li>
                <li><a href={usePath("/programa")} target="_blank" class="mobile-menu-link">{labels.programa}</a></li>
                <li><a href={`${homePrefix}#historia`} class="mobile-menu-link">{labels.historia}</a></li>
                <li class="mobile-menu-lang">
                    <a href={labels.switchUrl} class="mobile-menu-link mobile-menu-link--lang">
                        {labels.switchLang}
                    </a>
                </li>
            </ul>
        </nav>
        <div class="mobile-menu-social">
            <a href="https://instagram.com/kontrast.festival" target="_blank" class="social-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
            </a>
            <a href="mailto:festival.kontrast@gmail.com" class="social-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect width="20" height="16" x="2" y="4" rx="2"></rect>
                    <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
                </svg>
            </a>
        </div>
    </div>
    
    <slot />

    <aside class="social-sidebar">
        <div class="linea-decorativa"></div>
        <a href="https://instagram.com/kontrast.festival" target="_blank" class="social-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
        </a>
        <a href="mailto:festival.kontrast@gmail.com" class="social-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect width="20" height="16" x="2" y="4" rx="2"></rect>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
            </svg>
        </a>
    </aside>

    <script>
        // --- Menú hamburguesa mòbil ---
        const hamburgerBtn = document.getElementById('hamburger-btn');
        const overlay = document.getElementById('mobile-menu-overlay');

        function openMenu() {
            overlay.classList.add('is-open');
            hamburgerBtn.classList.add('is-active');
            document.body.style.overflow = 'hidden';
        }

        function closeMenu() {
            overlay.classList.remove('is-open');
            hamburgerBtn.classList.remove('is-active');
            document.body.style.overflow = '';
        }

        hamburgerBtn.addEventListener('click', () => {
            overlay.classList.contains('is-open') ? closeMenu() : openMenu();
        });

        // Tancar al fer clic en qualsevol enllaç del menú
        document.querySelectorAll('.mobile-menu-link').forEach(link => {
            link.addEventListener('click', closeMenu);
        });
    </script>

    <script>
    import { initScrollAnimations } from '../scripts/animations.js';
    initScrollAnimations();
</script>
</body>
</html>