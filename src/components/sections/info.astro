---
// src/components/sections/info.astro
const lang = Astro.currentLocale || 'ca';

const t = {
    horaris: lang === 'en' ? 'Opening Hours' : 'Horaris d’obertura',
    transport: lang === 'en' ? 'Transport' : 'Transport',
    bus_info: lang === 'en' 
        ? 'BUS Barcelona-Berga nearest stop: <br>Cal Rosal - Alternative stop: Berga' 
        : 'BUS Barcelona-Berga parada més propera: <br>Cal Rosal - Parada alternativa: Berga',
    cotxe_info: lang === 'en'
        ? 'From Barcelona Direction Túnel Cadí Highway C-16 Exit 92'
        : 'Des de Barcelona Direcció Túnel Cadí Autovia C-16 Sortida 92'
};
---

<div>
    <!-- ><h2 class="anim-left">INFO</h2> -->
        <img src="/img/info.webp" alt="entrades" class="titulos" style="scale:.7">


    <h1 style="text-align: center;">{t.horaris}</h1>
    <p class="horaris">
        10/04   18.00h (Pl. de la Vila, Gironella)<br>
        11/04   12.00h (Casserres)(+ espectacle gratuït a Casserres a les 12.00h)<br>
        12/04   13.30h (KONVENT)<br>
        <br>
        16/04   19.00h (KONVENT)<br>
        17/04   17.30h (KONVENT)<br>
        18/04   15.00h (KONVENT)<br>
        19/04   13.00h (KONVENT)
    </p>

    <h1 style="text-align: center;">{t.transport}</h1>
    <p class="horaris">
        <span set:html={t.bus_info} />
        <br>
        www.alsa.es
        <br><br>
        {t.cotxe_info}
    </p>
</div>

<div style="height: 5vh;"></div>