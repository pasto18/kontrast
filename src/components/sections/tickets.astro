---
// src/components/sections/tickets.astro
const lang = Astro.currentLocale || 'ca'; 

const t = {
    espectacle: lang === 'en' ? 'SHOW' : 'ESPECTACLE',
    concert: lang === 'en' ? 'CONCERT' : 'CONCERT',
    adult: lang === 'en' ? 'ADULT' : 'ADULT',
    infant: lang === 'en' ? 'CHILD' : 'INFANT',
    solidaria: lang === 'en' ? 'SOLIDARITY FARE*' : 'TARIFA SOLIDÀRIA*',
    nota_solidaria: lang === 'en' 
        ? '*The solidarity fare is for those who want to contribute a grain of sand to help make the festival more accessible to everyone. :)' 
        : '*El festival Kontrast és possible gràcies als diners recaptats amb les entrades. Si tens els mitjans i la voluntat d ajudar a sostenir el projecte, et proposem la tarifa solidària.',
    abonaments: lang === 'en' ? 'DAY & WEEKEND PASSES' : 'ABONAMENTS DE DIA i CAP de SETMANA',
    online_only: lang === 'en' ? 'ONLINE PURCHASE ONLY' : 'NOMÉS COMPRA ONLINE',
    comprar: lang === 'en' ? 'BUY TICKETS' : 'COMPRAR ENTRADES'
};
---

<style>
  /* ── Tabla desktop ── */
  .tickets-table-wrapper table {
    width: 100%;
    max-width: 700px;
    margin: 0 auto;
    border-collapse: collapse;
  }

  .tickets-table-wrapper th,
  .tickets-table-wrapper td {
    text-align: center;
    padding: 12px 16px;
    vertical-align: middle;
  }

  .tickets-table-wrapper td:first-child,
  .tickets-table-wrapper th:first-child {
    text-align: left;
  }

  hr.solid {
    border: none;
    border-top: 1px solid currentColor;
    margin: 0;
    opacity: 0.4;
    color: var(--c-negro);
  }

  /* ── Cards mobile: ocultas por defecto ── */
  .tickets-cards-header,
  .tickets-cards {
    display: none;
  }

  /* ── Abonaments ── */
  .abonaments-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    margin-top: 40px;
    padding: 0 16px;
  }

  .badge-online {
    /* Hereda h3 del global (3.5rem desktop, 1.5rem móvil) */
    text-align: center;
    background-color: var(--c-blanco);
    color: var(--c-rojo);
    width: fit-content;
    padding: 20px 40px;
    border-radius: 0px;
    margin-top: -40px;
    font-weight: 700;
    rotate: -2deg;
  }

  

  /* ── MOBILE ── */
  @media (max-width: 600px) {
    /* Ocultar tabla */
    .tickets-table-wrapper {
      display: none;
    }

    /* Mostrar header y cards */
    .tickets-cards-header {
      display: grid;
      grid-template-columns: 1fr 2fr 1fr;
      padding: 0 0%;
      margin-bottom: 8px;
    }

    .tickets-cards-header span {
      text-align: center;
      font-size: 1.3rem;  /* coherente con h3 mobile del global (1.5rem) */
      font-weight: 100;
      text-transform: uppercase;
      opacity: 1;
    }

    .tickets-cards-header span:first-child {
      text-align:left;
    }

    .tickets-cards {
      display: flex;
      flex-direction: column;
      width: 100%;
    }

    .ticket-card {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      align-items: center;
      padding: 16px 0%;
      border-top: 1px solid var(--c-negro);
    }

    .ticket-card .label {
      /* Usa el tamaño de h4 mobile — el global no lo reduce, así que lo hacemos aquí */
      font-size: 1.4rem;
      font-weight: 100;
      text-align: left;
      line-height: 1.2;
      
    }

    .ticket-card .price-block {
      text-align: center;
    }

    /* .preu en mobile: grande como el sistema tipográfico del site */
    .ticket-card .preu {
      font-size: 2.5rem !important;
      font-weight: 100;
      margin: 0;
      line-height: 1;
      text-align: center;
    }

    /* Badge "ONLINE ONLY" — el global ya reduce h3 a 1.5rem en mobile */
    .badge-online {
      padding: 12px 24px;
      margin-top: -30px !important;
      max-width: 85vw;
      font-size: 1.2rem; /* explícito para no depender de h3 en este contexto */
      color: var(--c-rojo);
    }

    /* Nota solidaria */
    .nota-solidaria {
      padding: 0 6%;
    }

    .nota-solidaria .p2 {
      width: 100% !important;
      font-size: 1.3rem;
    }

    .abonaments-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0px;
    margin-top: 5vh;
    padding: 0 16px;
    }
  }
</style>
<div style="background-color: var(--c-rojo);">
    
<div class="header-prog">
    <!-- <h2 class="anim-left">TICKETS</h2> -->
    <img src="/img/tickets.webp" alt="entrades" class="titulos" style="margin-bottom: 10vh; margin-top: 5vh;">
</div>

<div class="contenedor-principal">

  <!-- ── DESKTOP: tabla ── -->
  <div class="tickets-table-wrapper">
    <table>
      <thead>
        <tr>
          <th></th>
          <th><h4 style="margin:0; text-align:center; font-weight: 300; font-style: italic;">{t.espectacle}</h4></th>
          <th><h4 style="margin:0; text-align:center; font-weight: 300;font-style: italic">{t.concert}</h4></th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><h4 style="font-weight: 300; font-style: italic;">{t.adult}</h4></td>
          <td><h1 class="preu">12€</h1></td>
          <td><h1 class="preu">10€</h1></td>
        </tr>
        <tr><td colspan="3"><hr class="solid"/></td></tr>
        <tr>
          <td><h4 style="font-weight: 300; font-style: italic;">{t.infant}</h4></td>
          <td><h1 class="preu">8€</h1></td>
          <td><h1 class="preu">6€</h1></td>
        </tr>
        <tr><td colspan="3"><hr class="solid"/></td></tr>
        <tr>
          <td><h4 style="font-weight: 300; font-style: italic;">{t.solidaria}</h4></td>
          <td><h1 class="preu">15€</h1></td>
          <td><h1 class="preu">20€</h1></td>
        </tr>
        <tr><td colspan="3"><hr class="solid"/></td></tr>
      </tbody>
    </table>
  </div>

  <!-- ── MOBILE: header columnas ── -->
  <div class="tickets-cards-header">
    <span></span>
    <span>{t.espectacle}</span>
    <span>{t.concert}</span>
  </div>

  <!-- ── MOBILE: cards ── -->
  <div class="tickets-cards">
    <div class="ticket-card">
      <span class="label">{t.adult}</span>
      <div class="price-block"><h1 class="preu">12€</h1></div>
      <div class="price-block"><h1 class="preu">10€</h1></div>
    </div>
    <div class="ticket-card">
      <span class="label">{t.infant}</span>
      <div class="price-block"><h1 class="preu">8€</h1></div>
      <div class="price-block"><h1 class="preu">6€</h1></div>
    </div>
    <div class="ticket-card">
      <span class="label">{t.solidaria}</span>
      <div class="price-block"><h1 class="preu">15€</h1></div>
      <div class="price-block"><h1 class="preu">20€</h1></div>
    </div>
    <hr class="solid" style="margin: 0 0%; opacity: 1;" />
  </div>

</div>



<div class="abonaments-container">
    <h3 style="text-align: center;">{t.abonaments}</h3>
    <h3 class="badge-online">{t.online_only}</h3>

    <div class="nota-solidaria" style="margin-top: 5vh; text-align: center;">
    <p class="p2" style="background-color: transparent; color: var(--c-blanco);">{t.nota_solidaria}</p>
</div>


    <h1 class="btn-entrades" style="margin-top:10vh;"><a href="https://www.ticketic.org/ca/entrades/festival-kontrast-6" target="_blank" rel="noopener noreferrer">{t.comprar}</a></h1>
</div>

<div style="height: 15vh;"></div>

</div>