---
// src/components/sections/programacion.astro
import { getCollection } from 'astro:content';

const obras = await getCollection('obras');

// 1. Detectamos el idioma actual
const lang = Astro.currentLocale || 'ca';

// 2. Definimos la base de la URL para las obras
const baseRoute = lang === 'en' ? '/en/obras/' : '/obras/';

// 3. Traducciones para los textos de esta sección
const t = {
    titulo_seccion: lang === 'en' ? 'PROGRAM' : 'PROGRAMACIÓ'
};

function formatearFecha(fechaStr) {
    if (!fechaStr) return "";
    const fecha = new Date(fechaStr);
    
    const locale = lang === 'en' ? 'en-GB' : 'ca-ES';
    const diaSemana = fecha.toLocaleDateString(locale, { weekday: 'long' });
    const dia = fecha.getDate().toString().padStart(2, '0');
    const mes = (fecha.getMonth() + 1).toString().padStart(2, '0');
    return `${diaSemana} ${dia}/${mes}`.toUpperCase();
}

// --- LÓGICA DE AGRUPACIÓN ---
const obrasPorDia = {};
obras.forEach(obra => {
    obra.data.pases.forEach(pase => {
        const fechaKey = pase.fecha;
        const horaKey = pase.hora;

        if (!obrasPorDia[fechaKey]) {
            obrasPorDia[fechaKey] = [];
        }

        obrasPorDia[fechaKey].push({
            originalData: obra.data, 
            id: obra.id,      
            horaEspecifica: horaKey
        });
    });
});

const fechasOrdenadas = Object.keys(obrasPorDia).sort();

fechasOrdenadas.forEach(fecha => {
    obrasPorDia[fecha].sort((a, b) => {
        const horaA = parseInt(a.horaEspecifica.replace(':', ''));
        const horaB = parseInt(b.horaEspecifica.replace(':', ''));
        return horaA - horaB;
    });
});
---

<div class="programacion-container">
    
   <div class="header-prog">
    <!-- <h2 class="anim-left">{t.titulo_seccion}</h2>-->
    <img src="/public/img/programació.webp" alt="programacio" class="titulos">
</div>

    {fechasOrdenadas.map((fecha) => (
        <div class="bloque-dia">
            <div class="separador-fecha">
                <h2 class="anim-left">{formatearFecha(fecha)}</h2>
                <div class="linea"></div>
            </div>

            <div class="fila-obras">
                {obrasPorDia[fecha].map((item) => {
                    const data = item.originalData;
                    
                    const tipoShow = (data.categoria === 'Otro' && data.categoria_manual) 
                        ? data.categoria_manual 
                        : data.categoria;

                    return (
                        <a href={`${baseRoute}${item.id}`} class="card-link">
                            <article class="card-obra">
                                <div class="card-img-container">
                                    <img src={data.fotos[0]} alt={data.titulo} class="card-img"/>
                                </div>
                                
                                <div class="card-content">
                                    {tipoShow && <span class="etiqueta-tipo">{tipoShow}</span>}

                                    <div style="margin-top: auto; margin-bottom: auto; text-align: center; width: 100%;">
                                        <h2 class="card-titulo">{data.titulo}</h2>
                                        <p class="card-compania">{data.compania}</p>
                                    </div>

                                    <span class="card-fecha">
                                        {item.horaEspecifica}
                                    </span>
                                </div>
                            </article>
                        </a>
                    );
                })}
            </div>
        </div>
    ))}
</div>

<style>
  /* Solo en móvil: acordeón */
  @media (max-width: 768px) {

    /* El separador de fecha se convierte en botón */
    .separador-fecha {
      cursor: pointer;
      user-select: none;
      position: relative;
    }

    /* Indicador +/- al lado derecho */
    .separador-fecha::after {
      content: '+';
      font-size: 2rem;
      font-weight: 100;
      line-height: 1;
      position: absolute;
      right: 0;
      top: 50%;
      transform: translateY(-50%);
      transition: transform 0.3s ease, content 0.1s;
      color: var(--c-blanco);
      width: 2rem;
      text-align: center;
    }

    .separador-fecha.abierto::after {
      content: '−';
    }

    /* La fila de obras se oculta por defecto en móvil */
    .fila-obras {
      display: none;
      overflow: hidden;
    }

    /* Cuando el bloque está abierto, se muestra */
    .bloque-dia.abierto .fila-obras {
      display: flex;
    }

    /* --- EFECTE SCROLL MÒBIL ---
       Per defecte: B/N (igual que desktop sense hover) */
    .card-link {
      filter: grayscale(100%);
      transition: filter 0.4s ease;
    }

    /* Quan la fila té alguna card activa, les NO actives s'apaguen */
    .fila-obras.has-active .card-link:not(.mobile-active) {
      filter: grayscale(100%) brightness(0.7) blur(3px);
      opacity: 0.5;
    }

    /* La card activa (≥30% visible): color complet + info visible */
    .card-link.mobile-active {
      filter: none !important;
      opacity: 1 !important;
    }

    .card-link.mobile-active .card-content {
      opacity: 1;
    }
  }
</style>

<script>
  function initAcordeon() {
    // Solo activamos en móvil
    if (window.innerWidth > 768) return;

    const bloques = document.querySelectorAll('.bloque-dia');

    bloques.forEach((bloque) => {
      const separador = bloque.querySelector('.separador-fecha');
      if (!separador) return;

      separador.addEventListener('click', () => {
        const estaAbierto = bloque.classList.contains('abierto');

        // Cierra todos
        bloques.forEach((b) => {
          b.classList.remove('abierto');
          b.querySelector('.separador-fecha')?.classList.remove('abierto');
        });

        // Si estaba cerrado, abre este
        if (!estaAbierto) {
          bloque.classList.add('abierto');
          separador.classList.add('abierto');

          // Scroll suave hasta el bloque recién abierto
          setTimeout(() => {
            bloque.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }, 50);
        }
      });
    });
  }

  // Ejecutamos al cargar y también si cambia el tamaño de ventana
  document.addEventListener('DOMContentLoaded', initAcordeon);
  window.addEventListener('resize', initAcordeon);


  // --- EFECTE SCROLL MÒBIL ---
  // Quan una card ocupa ≥30% de la pantalla s'activa (color + info visible).
  // Quan en queda menys del 30%, torna a B/N sense info.

  function initMobileScrollCards() {
    if (window.innerWidth > 768) return;

    const cards = document.querySelectorAll('.card-link');
    if (!cards.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const fila = entry.target.closest('.fila-obras');

          if (entry.isIntersecting) {
            entry.target.classList.add('mobile-active');
            if (fila) fila.classList.add('has-active');
          } else {
            entry.target.classList.remove('mobile-active');
            if (fila && !fila.querySelector('.mobile-active')) {
              fila.classList.remove('has-active');
            }
          }
        });
      },
      { threshold: 0.8 }
    );

    cards.forEach((card) => observer.observe(card));
  }

  document.addEventListener('DOMContentLoaded', initMobileScrollCards);
  window.addEventListener('resize', initMobileScrollCards);
</script>