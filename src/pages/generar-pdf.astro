---
import Layout from '../layouts/layout.astro';
import { getCollection } from 'astro:content';

const obras = await getCollection('obras');

function getPrimerPaseTimestamp(obra) {
    const pase = obra.data.pases[0];
    const fecha = pase.fecha; // "2026-04-17"
    // Extraemos la hora del campo hora, que puede ser "22:00 - Konvent" o "19:30h Lloc"
    const horaMatch = pase.hora.match(/(\d{1,2}):(\d{2})/);
    const horas = horaMatch ? parseInt(horaMatch[1]) : 0;
    const minutos = horaMatch ? parseInt(horaMatch[2]) : 0;
    return new Date(`${fecha}T${String(horas).padStart(2,'0')}:${String(minutos).padStart(2,'0')}:00`).getTime();
}

const obrasOrdenadas = obras.sort((a, b) => getPrimerPaseTimestamp(a) - getPrimerPaseTimestamp(b));
const lang = Astro.currentLocale ?? 'ca';
const imgPrefix = lang === 'en' ? '/img/en' : '/img/ca';

function formatarData(fechaStr) {
    if (!fechaStr) return '';
    // Afegim T12:00:00 per evitar problemes de zona horària que desplacen el dia
    const fecha = new Date(fechaStr + 'T12:00:00');
    const dies = ['Dg', 'Dilluns', 'Dimarts', 'Dimecres', 'Dj', 'Dv', 'Ds'];
    const mesos = ['gen', 'feb', 'mar', 'abr', 'mai', 'jun', 'jul', 'ago', 'set', 'oct', 'nov', 'des'];
    const diaSemana = dies[fecha.getDay()];
    const dia = fecha.getDate();
    const mes = mesos[fecha.getMonth()];
    return `${diaSemana} ${dia}`;
}

function nlToBr(texto) {
    if (!texto) return '';
    return texto.replace(/\n/g, '<br>');
}

function getFontSize(texto) {
    if (!texto) return '15px';
    const len = texto.length;
    if (len > 1200) return '11px';
    if (len > 1000) return '14px';
    if (len > 800) return '15px';
    if (len > 600) return '18px';
    if (len > 400) return '20px';
    return '20px';
}
---

<Layout title="Generar Programa PDF">
    <div class="contenedor-principal">
        <div class="no-print" style="text-align: center; padding: 40px; color: white;">
          <img src="/img/cardonerpdf.webp" alt="Logo Kontrast" style="height:50vh; margin-bottom: -50px;" />  
          <h1 style="text-align: center;">Cardoner PDF Maker</h1>
            <p>Paciencia Laureta...triga una mica en fer el PDF.<br>
              No cal que esperis a que fagi la Vista Previa, pots clickear Guardar
            </p>
            <button id="download-btn" class="btn-entradas" style="cursor: pointer; padding: 15px 30px; background: #ffcc00; color: #000; font-weight: bold; border: none; border-radius: 50px;">
                DESCARREGAR PROGRAMA PDF
            </button>
        </div>

        <div id="pdf-content">

            <!-- PORTADA -->
            <div class="pdf-page pdf-cover">
                <img src="/img/kontrast buono.webp" alt="Portada Festival KONTRAST 2026" class="cover-img" />
            </div>
            <div class="pdf-page pdf-cover">
                <img src={`${imgPrefix}/k-1.webp`} alt="Portada Festival KONTRAST 2026" class="cover-img" />
            </div>
            <div class="pdf-page pdf-cover">
                <img src={`${imgPrefix}/k-2.webp`} alt="Portada Festival KONTRAST 2026" class="cover-img" />
            </div>
            <div class="pdf-page pdf-cover">
                <img src={`${imgPrefix}/k-3.webp`} alt="Portada Festival KONTRAST 2026" class="cover-img" />
            </div>
            

            {obrasOrdenadas.map((obra) => {
                const data = obra.data;
                const categoriaFinal = data.categoria === 'Otro' ? data.categoria_manual : data.categoria;
                const companiaFinal = data.compania && data.compania.trim() !== '-' ? data.compania : null;
            
                
                return (
                    <div class="pdf-page">
                        <div class="pdf-inner">
                            {data.fotos && data.fotos[0] && (
                                <div class="img-container">
                                    <img src={data.fotos[0]} crossorigin="anonymous" />
                                </div>
                            )}

                            <div class="header-overlay">
                                <span class="tag">{categoriaFinal}</span>
                                <h1 class="title">{data.titulo}</h1>
                                {companiaFinal && <h2 class="company">{companiaFinal}</h2>}
                            </div>

                            <div class="info-grid">
                                <div class="col col-dates">
                                    {data.pases.map(p => (
                                        <p class="text pase-item">
                                            <strong class="pase-dia">{formatarData(p.fecha)}</strong>
                                            <span class="pase-hora">{p.hora}</span>
                                        </p>
                                    ))}
                                </div>
                                <div class="col">
                                    <p class="text" 
                                        style={`font-size: ${getFontSize(lang === 'en' ? data.sinopsis_eng : data.sinopsis_cat)}`}
                                        set:html={nlToBr(lang === 'en' ? data.sinopsis_eng : data.sinopsis_cat)} />
                                </div>
                            </div>
                        </div>
                    </div>
                );
            })}
            <div class="pdf-page pdf-cover">
            <img src={`${imgPrefix}/k-4.webp`} alt="Contraportada" class="cover-img" />
        </div>
        </div>
    </div>
</Layout>

<style is:inline>
    #pdf-content { background: #3f3f3f; padding: 0; }

    .pdf-cover {
        padding: 0 !important;
        background: black;
    }

    .cover-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .pdf-page {
        background: rgb(0, 0, 0);
        width: 210mm;
        height: 296mm;
        margin: 0 auto 10mm auto;
        color: white;
        box-sizing: border-box;
        page-break-after: always;
        font-family: Arial, sans-serif;
        position: relative;
        overflow: hidden;
    }

    .img-container { 
        position: absolute;
        top: 0;
        left: 0;
        width: 100%; 
        height: 60%;
        z-index: 1;
    }
    .img-container img { width: 100%; height: 100%; object-fit: cover; }

    .header-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 60%;
        z-index: 2;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        padding: 40px;
        box-sizing: border-box;
        background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 60%);
    }

    .tag { 
        align-self: flex-start;
        border: 0px solid white; 
        padding: 4px 12px; 
        font-weight: bold; 
        text-transform: uppercase;
        font-size: 14px;
        margin-bottom: 15px;
        color: rgb(0, 0, 0);
        background-color: var(--c-blanco);
        border-radius: 30px;
    }

    .title { font-size: 3.5rem; margin: 0; line-height: 0.9; font-weight: 900; color: var(--c-blanco); }
    .company { font-size: 24px; margin: 10px 0 0 0; font-weight: normal; color: var(--c-blanco); }

    .info-grid { 
        position: absolute;
        top: 60%;
        left: 0;
        width: 100%;
        padding: 10px 10px 30px 20px;
        display: grid; 
        grid-template-columns: 1fr 5fr;
        gap: 0px;
        box-sizing: border-box;
    }

    /* Columna de fechas */
    .col-dates {
        padding-right: 10px;
    }

    .pase-item {
        text-align: left !important;
        margin-bottom: 10px !important;
    }

    .pase-dia {
        display: block;
        font-size: 19px;
        font-weight: 700;
        color: var(--c-rojo);
        line-height: 1.3;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .pase-hora {
        display: block;
        font-size: 14px;
        font-weight: 400;
        color: rgba(255, 255, 255, 0.7);
        line-height: 1.3;
    }

    .label { font-family: 'Helvetica Neue', Arial, sans-serif; font-size: 12px; text-decoration: underline; margin-bottom: 10px; color: #ffcc00; }
    .text { font-family: 'Helvetica Neue', Arial, sans-serif; font-size: 15px; line-height: 1.4; margin-bottom: 15px; color: #ffffff; text-align: justify; }

    @media print {
        body > *:not(.contenedor-principal),
        .contenedor-principal > *:not(#pdf-content),
        .no-print, header, nav, footer,
        .desktop-header, .mobile-menu-overlay,
        .hamburger-btn, .social-sidebar {
            display: none !important;
        }

        html, body {
            margin: 0 !important;
            padding: 0 !important;
            background: black !important;
        }

        .contenedor-principal {
            padding: 0 !important;
            margin: 0 !important;
            max-width: none !important;
        }

        #pdf-content { padding: 0 !important; margin: 0 !important; }

        .pdf-page {
            margin: 0 !important;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
            color-adjust: exact;
        }

        @page { margin: 0; padding: 0; size: A4 portrait; }
    }
</style>

<script is:inline>
    const btn = document.getElementById('download-btn');

    btn.addEventListener('click', () => {
        window.print();
    });
</script>