---
import fs from 'node:fs';
import path from 'node:path';

const obrasFiles = import.meta.glob('/src/content/obras/*.json', { eager: true });
const listaObras = Object.values(obrasFiles).map((file: any) => file.default || file);

const cssPath = path.resolve('./src/styles/global.css');
const globalCSS = fs.readFileSync(cssPath, 'utf-8');

function formatearFechaPrograma(fechaStr: string) {
    if (!fechaStr) return "";
    const [year, month, day] = fechaStr.split('-').map(Number);
    const date = new Date(year, month - 1, day);
    const diesSetmana = [
        "Diumenge", "Dilluns", "Dimarts", "Dimecres", "Dijous", "Divendres", "Dissabte"
    ];
    const diaNom = diesSetmana[date.getDay()];
    const diaNum = day.toString().padStart(2, '0');
    const mesNum = month.toString().padStart(2, '0');
    return `${diaNom} ${diaNum}/${mesNum}`;
}
---

<!DOCTYPE html>
<html lang="ca">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KONTRAST Programa 2026</title>
    <link rel="manifest" href="/programa/manifest.json">

    <style is:inline set:html={globalCSS}></style>

    <style>
        :global(html), :global(body) {
            background: #000 !important;
            margin: 0;
            padding: 0;
            color: #fff;
            font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
        }

        .lista-container {
            width: 100%;
            max-width: 600px;
            margin: 0 auto;
        }

        /* ── Fila compacta (siempre visible) ── */
        .obra-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 18px 20px;
            border-bottom: 1px solid #222;
            cursor: pointer;
            user-select: none;
            transition: background 0.15s;
            gap: 12px;
        }
        .obra-row:hover {
            background: #111;
        }
        .obra-row.activa {
            border-bottom-color: transparent;
        }

        .obra-row-info {
            flex: 1;
            min-width: 0;
        }
        .obra-row-titulo {
            font-size: 1.3rem;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: -0.5px;
            line-height: 1;
            color: #fff;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .obra-row-compania {
            font-size: 0.85rem;
            color: #888;
            margin-top: 3px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .obra-row-arrow {
            color: #555;
            font-size: 1rem;
            flex-shrink: 0;
            transition: transform 0.25s ease, color 0.15s;
        }
        .obra-row.activa .obra-row-arrow {
            transform: rotate(180deg);
            color: #fff;
        }

        /* ── Panel expandido ── */
        .obra-panel {
            display: none;
            border-bottom: 1px solid #ffffff;
        }
        .obra-panel.abierto {
            display: block;
        }

        /* Contenido del panel — estilos originales */
        .hero-container {
            position: relative;
            width: 100%;
            height: 50vh;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            align-items: flex-start;
        }
        .hero-img {
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 100%;
            object-fit: cover;
            z-index: 0;
        }
        .hero-gradient {
            position: absolute;
            bottom: 0; left: 0;
            width: 100%; height: 100%;
            background: linear-gradient(to top, rgba(0,0,0,1) 0%, rgba(0,0,0,0.4) 50%, rgba(0,0,0,0) 100%);
            z-index: 1;
        }
        .hero-text {
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            z-index: 2;
            padding: 20px;
            display: flex;
            flex-direction: column;
            justify-content: flex-start;
        }
        .bottom-group {
            margin-top: auto;
            width: 100%;
        }
        .categoria-tag {
            display: inline-block;
            font-size: .9rem;
            font-weight: bold;
            color: #000 !important;
            background: #fff !important;
            padding: 3px 10px;
            border-radius: 50px;
            text-transform: uppercase;
            width: fit-content;
        }
        .obra-titulo {
            font-size: 2.8rem;
            margin: 0;
            color: #fff;
            text-transform: uppercase;
            font-weight: 900;
            line-height: 0.85;
            letter-spacing: -1px;
        }
        .obra-compania {
            font-size: 1.1rem;
            margin: 0;
            color: #ffffff;
            background-color: transparent;
            border-color: transparent;
            font-weight: 400;
            padding: 0;
        }
        .info-container {
            padding: 0px 20px 30px 20px;
            background: #000;
        }
        .pases-box {
            font-size: 1.4rem;
            font-weight: 700;
            margin-bottom: 12px;
        }
        .sinopsis {
            color: #ffffff;
            line-height: 1.4;
            font-size: 1rem;
            text-align: justify;
            white-space: pre-line;
        }

        /* ── Botón PDF (solo desktop) ── */
        #k-pdf-btn {
            position: fixed;
            top: 16px; right: 16px;
            z-index: 9998;
            background: #fff;
            color: #000;
            border: none;
            border-radius: 50px;
            padding: 8px 18px;
            font-size: 0.85rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            cursor: pointer;
            font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
            box-shadow: 0 2px 12px rgba(0,0,0,0.4);
        }
        #k-pdf-btn:hover { background: #eee; }

        /* ── Banner instalación ── */
        #k-install-banner {
            position: fixed;
            bottom: 0; left: 0; right: 0;
            z-index: 9999;
            background: #111;
            border-top: 1px solid #333;
            padding: 16px 20px;
            display: flex;
            flex-direction: column;
            gap: 12px;
            font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
            animation: slideUp 0.3s ease;
        }
        @keyframes slideUp {
            from { transform: translateY(100%); opacity: 0; }
            to   { transform: translateY(0);    opacity: 1; }
        }
        #k-install-banner .k-banner-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
        }
        #k-install-banner .k-banner-text {
            font-size: 0.95rem;
            color: #ccc;
            line-height: 1.4;
            flex: 1;
        }
        #k-install-banner .k-banner-text strong {
            color: #fff;
            display: block;
            margin-bottom: 2px;
            font-size: 1rem;
        }
        #k-install-banner .k-close {
            background: none;
            border: none;
            color: #666;
            font-size: 1.4rem;
            cursor: pointer;
            padding: 4px;
            line-height: 1;
            flex-shrink: 0;
        }
        #k-install-banner .k-install-btn {
            background: #fff;
            color: #000;
            border: none;
            border-radius: 50px;
            padding: 10px 20px;
            font-size: 0.9rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            cursor: pointer;
            width: 100%;
        }
        #k-install-banner .k-ios-steps {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }
        #k-install-banner .k-ios-step {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 0.88rem;
            color: #aaa;
        }
        #k-install-banner .k-ios-step .k-step-num {
            background: #333;
            color: #fff;
            border-radius: 50%;
            width: 22px; height: 22px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.75rem;
            font-weight: 700;
            flex-shrink: 0;
        }

        /* ── Print ── */
        @media print {
            #k-install-banner, #k-pdf-btn { display: none !important; }
            body { background: #fff !important; color: #000 !important; }
            .obra-row { display: none; }
            .obra-panel { display: block !important; border-bottom: 1px solid #ccc !important; }
            .hero-container { height: 35vh !important; }
            .hero-img { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
            .obra-titulo { color: #000 !important; font-size: 2rem !important; }
            .obra-compania, .sinopsis, .fecha-label, .hora-label { color: #000 !important; }
            .info-container { background: #fff !important; }
            .hero-gradient { display: none; }
            .categoria-tag { background: #000 !important; color: #fff !important; }
        }
    </style>

    <script is:inline>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/programa/sw.js', { scope: '/programa/' })
                    .then(() => console.log('✅ SW Activo'))
                    .catch(err => console.error('❌ Error:', err));
            });
        }
    </script>
</head>

<body>

    <h2 style="text-align: center;font-size: clamp(4rem, 2.5vw, 6rem);"> KONTRAST #6</h2>
    <main class="lista-container">
        {listaObras.map((obra, i) => {
            const categoriaAMostrar = (obra.categoria === 'Otro' && obra.categoria_manual)
                ? obra.categoria_manual
                : (obra.categoria || 'CIRC');

            return (
                <div class="obra-card" data-index={i}>
                    {/* Fila compacta siempre visible */}
                    <div class="obra-row" data-index={i}>
                        <div class="obra-row-info">
                            <div class="obra-row-titulo">{obra.titulo}</div>
                            {obra.compania !== '-' && <div class="obra-row-compania">{obra.compania}</div>}

                        </div>
                        <span class="obra-row-arrow">▼</span>
                    </div>

                    {/* Panel expandido */}
                    <div class="obra-panel" data-index={i}>
                        <div class="hero-container">
                            {obra.fotos && obra.fotos.length > 0 && (
                                <img src={obra.fotos[0]} class="hero-img" alt={obra.titulo} />
                            )}
                            <div class="hero-gradient"></div>
                            <div class="hero-text">
                                <span class="categoria-tag">{categoriaAMostrar}</span>
                                <div class="bottom-group">
                                    <h2 class="obra-titulo">{obra.titulo}</h2>
                                   {obra.compania !== '-' && <p class="obra-compania">{obra.compania}</p>}
                                </div>
                            </div>
                        </div>

                        <div class="info-container">
                            {obra.pases && obra.pases.map((p: any) => (
                                <div class="pases-box">
                                    <span class="fecha-label">{formatearFechaPrograma(p.fecha)}</span>
                                    <span class="hora-label"> — {p.hora}</span>
                                </div>
                            ))}
                            <div class="sinopsis">
                                {obra.sinopsis_eng || obra.sinopsis}
                            </div>
                        </div>
                    </div>
                </div>
            );
        })}
    </main>

    <script is:inline>
    // ── Acordeón ─────────────────────────────────────────────────────────────
    (function () {
        let panelAbierto = null;
        let rowActiva = null;

        document.querySelectorAll('.obra-row').forEach(function (row) {
            row.addEventListener('click', function () {
                const idx = this.getAttribute('data-index');
                const panel = document.querySelector('.obra-panel[data-index="' + idx + '"]');

                // Si ya está abierto, ciérralo
                if (panelAbierto === panel) {
                    panel.classList.remove('abierto');
                    this.classList.remove('activa');
                    panelAbierto = null;
                    rowActiva = null;
                    return;
                }

                // Cerrar el anterior
                if (panelAbierto) {
                    panelAbierto.classList.remove('abierto');
                    rowActiva.classList.remove('activa');
                }

                // Abrir el nuevo
                panel.classList.add('abierto');
                this.classList.add('activa');
                panelAbierto = panel;
                rowActiva = this;

                // Scroll suave hasta la fila
                setTimeout(function () {
                    row.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }, 50);
            });
        });
    })();
    </script>

    <script is:inline>
    // ── Banner instalación + botón PDF ───────────────────────────────────────
    (function () {
        const isIOS = /iphone|ipad|ipod/i.test(navigator.userAgent);
        const isAndroid = /android/i.test(navigator.userAgent);
        const isMobile = isIOS || isAndroid;
        const isStandalone = window.matchMedia('(display-mode: standalone)').matches || navigator.standalone === true;
        const alreadyDismissed = localStorage.getItem('kontrast-banner-dismissed');

        if (isStandalone || alreadyDismissed) return;

        if (isMobile) {
            const banner = document.createElement('div');
            banner.id = 'k-install-banner';

            if (isIOS) {
                banner.innerHTML = `
                    <div class="k-banner-top">
                        <div class="k-banner-text">
                            <strong>Instal·la el Programa</strong>
                            Accedeix sense connexió a internet
                        </div>
                        <button class="k-close" id="k-close-btn">✕</button>
                    </div>
                    <div class="k-ios-steps">
                        <div class="k-ios-step">
                            <span class="k-step-num">1</span>
                            <span>Prem el botó <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#aaa" stroke-width="2"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg> Compartir de Safari</span>
                        </div>
                        <div class="k-ios-step">
                            <span class="k-step-num">2</span>
                            <span>Selecciona <strong style="color:#fff">"Afegir a la pantalla d'inici"</strong></span>
                        </div>
                        <div class="k-ios-step">
                            <span class="k-step-num">3</span>
                            <span>Prem <strong style="color:#fff">"Afegir"</strong> a dalt a la dreta</span>
                        </div>
                    </div>`;
            } else {
                banner.innerHTML = `
                    <div class="k-banner-top">
                        <div class="k-banner-text">
                            <strong>Instal·la el Programa</strong>
                            Accedeix sense connexió a internet
                        </div>
                        <button class="k-close" id="k-close-btn">✕</button>
                    </div>
                    <button class="k-install-btn" id="k-android-install">⬇ Descarregar app</button>`;
            }

            document.body.appendChild(banner);

            document.getElementById('k-close-btn').addEventListener('click', function () {
                banner.remove();
                localStorage.setItem('kontrast-banner-dismissed', '1');
            });

            if (isAndroid) {
                let deferredPrompt = null;
                window.addEventListener('beforeinstallprompt', function (e) {
                    e.preventDefault();
                    deferredPrompt = e;
                });
                document.getElementById('k-android-install').addEventListener('click', async function () {
                    if (deferredPrompt) {
                        deferredPrompt.prompt();
                        const { outcome } = await deferredPrompt.userChoice;
                        if (outcome === 'accepted') {
                            banner.remove();
                            localStorage.setItem('kontrast-banner-dismissed', '1');
                        }
                        deferredPrompt = null;
                    } else {
                        document.getElementById('k-android-install').textContent = 'Menú ⋮ → "Instal·lar aplicació"';
                    }
                });
            }
        } else {
            const pdfBtn = document.createElement('button');
            pdfBtn.id = 'k-pdf-btn';
            pdfBtn.textContent = '⬇ Descargar PDF';
            pdfBtn.addEventListener('click', function () { window.print(); });
            document.body.appendChild(pdfBtn);
        }
    })();
    </script>

</body>
</html>