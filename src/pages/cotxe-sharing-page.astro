---
import Layout from '../layouts/layout.astro';
import MenuAlternativo from '../components/MenuAlternativo.astro';
---

<Layout title="Cotxe-Sharing">

        

  <div class="contenedor-principal" style="margin-top: 0vh;">
    <h2>COTXE-SHARING!</h2>
    <a href="https://forms.gle/1FD66L1xQsGi1rED7" target="_blank" style="text-decoration: none;">
        <h3 class="boton-formulario">Omple el formulari per OFERIR o BUSCAR viatge.</h3>
    </a>
</div>
    

    <div class="controles-viajes" style="margin-top: 10vh;">
    <button id="btn-todos">Tots</button>
    <button id="btn-busco">Busco</button>
    <button id="btn-ofrezco">Ofereixo</button>
    <select id="ordenarFecha">
        <option value="asc">Fecha: Próximos primero</option>
        <option value="desc">Fecha: Últimos primero</option>
    </select>
</div>

<div class="contenedor-principal-viajes">
    <div class="contenedor-tarjetas" id="tarjetas-container">
        <p style="text-align: center; width: 100%;">Cargando viajes...</p>
    </div>
</div>

<script>
    let todosLosViajes = []; 
    let viajesFiltrados = [];

    async function cargarDatos() {
        const apiKey = 'AIzaSyDCgnL_oc1lTa_9Lsn3TWwQiKx9aYZ5qCM';
        const spreadsheetId = '1Tm4RU-un_72kFzHPLUO7gbCzupMnSgIJFc6dwh6P23s';
        const range = 'KO_VIAJES_ORDENADO!A:Z';

        try {
            const url = `https://sheets.googleapis.com/v4/spreadsheets/${spreadsheetId}/values/${range}?key=${apiKey}&valueRenderOption=FORMATTED_VALUE`;
            const response = await fetch(url);
            const data = await response.json();
            
            if (!data.values || data.values.length <= 1) {
                document.getElementById('tarjetas-container').innerHTML = "<p>No hay viajes disponibles.</p>";
                return;
            }

            const rawViajes = data.values.slice(1);
            const hoy = new Date();
            hoy.setHours(0, 0, 0, 0); 

            todosLosViajes = rawViajes.filter(fila => {
                if (!fila[1]) return false;
                const fechaViaje = convertirFecha(fila[1]);
                
                // Si la fecha es de hoy o futura, la mostramos
                return !isNaN(fechaViaje.getTime()) && fechaViaje >= hoy;
            });

            viajesFiltrados = [...todosLosViajes];
            
            if (todosLosViajes.length === 0) {
                document.getElementById('tarjetas-container').innerHTML = "<p style='text-align:center;'>No hay viajes próximos disponibles.</p>";
                return;
            }

            ordenarPorFecha(document.getElementById('ordenarFecha').value);

        } catch (error) {
            console.error("Error:", error);
            document.getElementById('tarjetas-container').innerHTML = "<p>Error de carga.</p>";
        }
    }

    function mostrarTarjetas(filas) {
        const container = document.getElementById('tarjetas-container');
        container.innerHTML = ''; 

        filas.forEach(fila => {
            const idxFecha = 1, idxHora = 2, idxDesde = 3, idxPlazas = 4, 
                  idxNom = 5, idxCont = 6, idxComen = 7, idxTipo = 8, idxDesti = 9;

            const tipoViaje = (fila[idxTipo] || '').trim();
            const tarjeta = document.createElement('div');
            tarjeta.className = `tarjeta ${tipoViaje === "Busco Viatge" ? 'tarjeta-busco' : 'tarjeta-ofrezco'}`;

            let htmlInner = `
                <div class="cabecera-tarjeta">
                    <span class="tipo-header">${tipoViaje === "Busco Viatge" ? 'BUSCO' : 'OFEREIXO'}</span>
                    <span class="fecha-header"> ${fila[idxFecha] || ''}</span>
                </div>
            `;

            const camposCuerpo = [
                { idx: idxDesde, label: "Desde" },
                { idx: idxDesti, label: "Fins a" },
                { idx: idxHora, label: "Hora" },
                { idx: idxPlazas, label: "Places" },
                { idx: idxNom, label: "Nom" },
                { idx: idxCont, label: "Contacte" },
                { idx: idxComen, label: "Comentaris" }
            ];

            camposCuerpo.forEach(campo => {
                const valor = fila[campo.idx];
                if (valor && valor.toString().trim() !== "") {
                    htmlInner += `<div class="campo"><strong>${campo.label}:</strong> <span>${valor}</span></div>`;
                }
            });

            tarjeta.innerHTML = htmlInner;
            container.appendChild(tarjeta);
        });
    }

    function filtrarViajes(tipo) {
        viajesFiltrados = (tipo === 'todos') 
            ? [...todosLosViajes] 
            : todosLosViajes.filter(f => (f[8] || '').trim() === tipo);
        ordenarPorFecha(document.getElementById('ordenarFecha').value);
    }

    function ordenarPorFecha(orden) {
        viajesFiltrados.sort((a, b) => {
            const da = convertirFecha(a[1]), db = convertirFecha(b[1]);
            return orden === 'asc' ? da - db : db - da;
        });
        mostrarTarjetas(viajesFiltrados);
    }

    function convertirFecha(valor) {
        if (!valor) return new Date(0);
        const str = valor.toString().trim();
        const partes = str.split(/[\/\-]/);
        
        let dia, mes, anio;

        if (partes.length === 2) {
            // Caso detectado: "5/04" -> Asumimos día, mes y año actual (2026)
            dia = parseInt(partes[0], 10);
            mes = parseInt(partes[1], 10) - 1;
            anio = 2026; 
        } else if (partes.length === 3) {
            // Caso completo: "5/04/2026"
            dia = parseInt(partes[0], 10);
            mes = parseInt(partes[1], 10) - 1;
            anio = parseInt(partes[2], 10);
            if (anio < 100) anio += 2000;
        } else {
            return new Date(valor);
        }

        return new Date(anio, mes, dia);
    }

    document.addEventListener('DOMContentLoaded', () => {
        cargarDatos();
        document.getElementById('btn-todos').onclick = () => filtrarViajes('todos');
        document.getElementById('btn-busco').onclick = () => filtrarViajes('Busco Viatge');
        document.getElementById('btn-ofrezco').onclick = () => filtrarViajes('Ofereixo Viatge');
        document.getElementById('ordenarFecha').onchange = (e) => ordenarPorFecha(e.target.value);
    });
</script>


</Layout>

