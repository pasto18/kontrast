---
import Layout from '../layouts/layout.astro';
import IconoMapa from '../components/IconoMapa.astro';
import MenuAlternativo from '../components/MenuAlternativo.astro';
---

<Layout title="Mapa">

<div class="mapa-wrapper">

  <div class="map-container">
    <iframe 
      src="https://www.google.com/maps/d/embed?mid=1rtnzDdEt542sQZ6KaW0PI6_6TlZA5G4&amp;ehbc=2E312F" 
      allowfullscreen
    ></iframe>
  </div>

  <div class="locations-panel">
    
    <div class="location-group">
      <h2 class="small location-title">CAL ROSAL</h2>
      <div class="location-links">
        <a href="https://maps.app.goo.gl/bTLAL3AGdbC313A99" target="_blank" class="location-link"><IconoMapa /> KONVENT</a>
        <a href="https://maps.app.goo.gl/7wj6WnaXLWo2FBd5A" target="_blank" class="location-link"><IconoMapa /> Teatre Cal Rosal</a>
        <a href="https://maps.app.goo.gl/jwmQgTg2aNNBWCpdA" target="_blank" class="location-link"><IconoMapa /> Carpa SIDE</a>
        <a href="https://maps.app.goo.gl/UxfghWrXTmLuz53T9" target="_blank" class="location-link"><IconoMapa /> Carpa Bêtes de Foire</a>
      </div>
    </div>

    <div class="location-group">
      <h2 class="small location-title">GIRONELLA</h2>
      <a href="https://maps.app.goo.gl/RKyN8nibLWUvrZG37" target="_blank" class="location-link"><IconoMapa /> Pl. de la Vila</a>
    </div>

    <div class="location-group last">
      <h2 class="small location-title">CASSERRES</h2>
      <a href="https://maps.app.goo.gl/mkibhQPiwLu9fDCa6" target="_blank" class="location-link"><IconoMapa /> Casserres</a>
    </div>

  </div>

</div>

</Layout>

<style>
  /* ── MOBILE: panel abajo, mapa arriba ── */
  .mapa-wrapper {
    position: fixed;
    inset: 0;
    display: flex;
    flex-direction: column;
    z-index: 1;
  }

  .map-container {
    flex: 2;
    position: relative;
    overflow: hidden;
  }

  .map-container iframe {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
  }

  .locations-panel {
    flex: 1;
    background-color: var(--c-rojo);
    padding: 20px 16px;
    color: #fff;
    font-family: sans-serif;
    overflow-y: auto;
    border-radius: 14px 14px 0 0;
    box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.2);
  }

  /* ── DESKTOP: panel flotante, mapa de fondo ── */
  @media (min-width: 768px) {
    .mapa-wrapper {
      display: block;
      position: fixed;
      inset: 0;
    }

    .map-container {
      position: absolute;
      inset: 0;
    }

    .locations-panel {
      position: absolute;
      width: 25%;
      top: 20vh;
      left: 5vw;
      z-index: 1;
      padding: 25px 20px;
      border-radius: 10px;
      box-shadow: none;
      overflow-y: visible;
    }
  }

  /* ── Estilos compartidos ── */
  .location-group {
    margin-bottom: 25px;
  }

  .location-group.last {
    margin-bottom: 10px;
  }

  .location-title {
    margin: 0 0 15px 0;
    line-height: 1.2;
    font-weight: normal;
    font-style: italic;
  }

  .location-links {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .location-link {
    color: inherit;
    text-decoration: none;
    font-size: 1.5rem;
  }

  /* Mobile: tamaño algo menor */
  @media (max-width: 767px) {
    .location-group {
      margin-bottom: 14px;
    }

    .location-title {
      margin-bottom: 8px;
    }

    .location-links {
      gap: 6px;
    }

    .location-link {
      font-size: 1.1rem;
    }
  }
</style>